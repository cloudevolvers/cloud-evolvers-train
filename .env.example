# Cloud Evolvers Environment Variables
# Copy this file to .env and fill in the actual values
# NEVER commit .env to git!

# Cloudflare API Tokens (set in Cloudflare dashboard for production)
# These tokens are IP-whitelisted for security
CLOUDFLARE_DNS_TOKEN=your_dns_token_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Image API Keys (for downloading training course images)
PEXELS_API_KEY=your_pexels_api_key_here
UNSPLASH_APP_ID=your_unsplash_app_id_here
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here

# Environment
VITE_ENVIRONMENT=development
